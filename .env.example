# Database — Supabase PostgreSQL connection string
DATABASE_URL=

# Auth.js v5
AUTH_URL=http://localhost:3000
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Apple OAuth — https://developer.apple.com/account/resources/identifiers
# Set all three to enable Apple sign-in (provider + UI button)
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
NEXT_PUBLIC_APPLE_ENABLED=

# Mapbox GL JS — https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=
